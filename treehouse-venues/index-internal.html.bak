  // SOHO / BOWERY (0.5-0.9 mi)
  { name: "The Kubricks Plan", neighborhood: "Lower East Side", type: "event", capacity: 1000, capacitySit: 300, price: "From $1,000/hr", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/87169/the-kubricks-plan/entire-venue", source: "TagVenue", features: ["BYO alcohol","Play your own music","Whole venue","Theatre"], desc: "MASSIVE 1000-person theatre on the LES. Full buyout. Insane scale for a mega Treehouse event.", match: 85, lower: true, emoji: "🎭", dist: 1.2 },
