<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Treehouse Venue Finder</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f0f0f;
  --card: #1a1a1a;
  --card-hover: #222;
  --accent: #4ade80;
  --accent2: #22d3ee;
  --text: #e5e5e5;
  --text-dim: #888;
  --border: #2a2a2a;
  --gold: #fbbf24;
  --red: #f87171;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }

/* HEADER */
.header { padding: 2rem; text-align: center; border-bottom: 1px solid var(--border); }
.header h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 800; }
.header h1 span { color: var(--accent); }
.header p { color: var(--text-dim); font-size: .9rem; margin-top: .5rem; }
.event-dates { display: flex; justify-content: center; gap: 1rem; margin-top: 1rem; }
.event-dates .date-badge { background: linear-gradient(135deg, #4ade8033, #22d3ee33); border: 1px solid var(--accent); padding: .5rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: .9rem; }

/* FILTERS */
.filters { display: flex; flex-wrap: wrap; gap: .5rem; padding: 1.5rem 2rem; justify-content: center; border-bottom: 1px solid var(--border); }
.filter-btn { background: var(--card); border: 1px solid var(--border); color: var(--text-dim); padding: .4rem .8rem; border-radius: 6px; font-size: .8rem; cursor: pointer; transition: all .2s; }
.filter-btn:hover, .filter-btn.active { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 600; }
.search-box { background: var(--card); border: 1px solid var(--border); color: var(--text); padding: .5rem 1rem; border-radius: 8px; font-size: .85rem; width: 250px; }
.search-box::placeholder { color: var(--text-dim); }

/* STATS */
.stats { display: flex; justify-content: center; gap: 2rem; padding: 1rem 2rem; }
.stat { text-align: center; }
.stat .num { font-size: 1.5rem; font-weight: 800; color: var(--accent); }
.stat .label { font-size: .7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }

/* GRID */
.venue-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1rem; padding: 1.5rem 2rem; max-width: 1400px; margin: 0 auto; }
.venue-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all .2s; cursor: pointer; }
.venue-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(74,222,128,.1); }
.venue-img { height: 180px; background: linear-gradient(135deg, #1a2a1a, #0a1a2a); display: flex; align-items: center; justify-content: center; font-size: 2rem; position: relative; }
.venue-img .source-tag { position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,.7); padding: 2px 8px; border-radius: 4px; font-size: .65rem; color: var(--text-dim); }
.venue-img .match-score { position: absolute; top: 8px; left: 8px; background: var(--accent); color: #000; padding: 2px 8px; border-radius: 4px; font-size: .7rem; font-weight: 700; }
.byo-badge { position: absolute; bottom: 8px; left: 8px; padding: 3px 10px; border-radius: 4px; font-size: .7rem; font-weight: 700; }
.byo-badge.yes { background: #4ade80; color: #000; }
.byo-badge.no { background: #f8717166; color: #f87171; border: 1px solid #f87171; }
.cap-badge { position: absolute; bottom: 8px; right: 8px; background: #fbbf24; color: #000; padding: 3px 10px; border-radius: 4px; font-size: .7rem; font-weight: 700; }
.music-badge { position: absolute; bottom: 32px; left: 8px; padding: 3px 10px; border-radius: 4px; font-size: .7rem; font-weight: 700; }
.music-badge.yes { background: #a78bfa; color: #000; }
.music-badge.no { background: #a78bfa33; color: #a78bfa; border: 1px solid #a78bfa; }
.venue-card.no-music { opacity: 0.4; }
.venue-card.no-music:hover { opacity: 0.8; }
.venue-card.no-byo { opacity: 0.5; }
.venue-card.no-byo:hover { opacity: 0.85; }
.venue-body { padding: 1rem; }
.venue-body h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; margin-bottom: .25rem; }
.venue-body .neighborhood { color: var(--accent2); font-size: .8rem; font-weight: 600; }
.venue-meta { display: flex; flex-wrap: wrap; gap: .5rem; margin: .75rem 0; }
.venue-meta .tag { background: var(--bg); padding: .2rem .5rem; border-radius: 4px; font-size: .7rem; color: var(--text-dim); border: 1px solid var(--border); }
.venue-meta .tag.green { border-color: var(--accent); color: var(--accent); }
.venue-meta .tag.gold { border-color: var(--gold); color: var(--gold); }
.venue-details { display: flex; justify-content: space-between; align-items: center; margin-top: .75rem; padding-top: .75rem; border-top: 1px solid var(--border); }
.venue-price { font-weight: 700; color: var(--gold); font-size: .9rem; }
.venue-capacity { font-size: .85rem; color: var(--accent2); font-weight: 700; }
.venue-capacity-bar { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: .4rem .6rem; margin-top: .5rem; display: flex; align-items: center; gap: .5rem; }
.venue-capacity-bar .cap-num { font-size: 1.1rem; font-weight: 800; color: var(--accent); }
.venue-capacity-bar .cap-label { font-size: .7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: .5px; }
.venue-capacity-bar .cap-divider { width: 1px; height: 24px; background: var(--border); }
.cap-meter { flex: 1; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.cap-meter-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--accent), var(--accent2)); }
.venue-link { display: inline-block; background: var(--accent); color: #000; padding: .35rem .75rem; border-radius: 6px; font-size: .75rem; font-weight: 700; text-decoration: none; transition: all .2s; }
.venue-link:hover { background: #22d3ee; }

/* TRACKER */
.tracker-section { max-width: 1400px; margin: 2rem auto; padding: 0 2rem; }
.tracker-section h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 1rem; }
.tracker-table { width: 100%; border-collapse: collapse; }
.tracker-table th { background: var(--card); color: var(--accent); padding: .6rem; font-size: .75rem; text-transform: uppercase; letter-spacing: .5px; text-align: left; border-bottom: 1px solid var(--border); }
.tracker-table td { padding: .5rem .6rem; border-bottom: 1px solid var(--border); font-size: .8rem; }
.tracker-table tr:hover { background: var(--card); }
#noShortlist { color: var(--text-dim); font-size: .85rem; padding: 1rem 0; }

/* FOOTER */
.footer { text-align: center; padding: 2rem; color: var(--text-dim); font-size: .75rem; border-top: 1px solid var(--border); margin-top: 2rem; }

@media(max-width:768px) {
  .venue-grid { grid-template-columns: 1fr; padding: 1rem; }
  .header h1 { font-size: 1.75rem; }
  .filters { padding: 1rem; }
}
</style>
</head>
<body>

<div class="header">
  <h1>🌳 <span>Treehouse</span> Venue Finder</h1>
  <p>NYC venues for 150+ guests / BYO alcohol / loud music / Sorted by distance from West Village</p>
  <div class="event-dates">
    <div class="date-badge">📅 Thursday, April 17</div>
    <div class="date-badge">📅 Thursday, April 24</div>
  </div>
</div>

<div class="filters">
  <input type="text" class="search-box" id="venueSearch" placeholder="🔍 Search venues..." oninput="filterVenues()">
  <button class="filter-btn active" data-f="all" onclick="setFilter('all',this)">All</button>
  <button class="filter-btn" data-f="loft" onclick="setFilter('loft',this)">Lofts</button>
  <button class="filter-btn" data-f="warehouse" onclick="setFilter('warehouse',this)">Warehouses</button>
  <button class="filter-btn" data-f="rooftop" onclick="setFilter('rooftop',this)">Rooftops</button>
  <button class="filter-btn" data-f="bar" onclick="setFilter('bar',this)">Bars/Clubs</button>
  <button class="filter-btn" data-f="gallery" onclick="setFilter('gallery',this)">Galleries</button>
  <button class="filter-btn" data-f="restaurant" onclick="setFilter('restaurant',this)">Restaurants</button>
  <button class="filter-btn" data-f="event" onclick="setFilter('event',this)">Event Spaces</button>
  <button class="filter-btn" data-f="lower" onclick="setFilter('lower',this)">Lower Manhattan</button>
  <button class="filter-btn" data-f="ready" onclick="setFilter('ready',this)">✅ Event Ready (BYO + Music)</button>
  <button class="filter-btn" data-f="byo" onclick="setFilter('byo',this)">🍾 BYO Alcohol</button>
  <button class="filter-btn" data-f="music" onclick="setFilter('music',this)">🎵 Loud Music</button>
  <button class="filter-btn" data-f="cap250" onclick="setFilter('cap250',this)">🔥 250+ Capacity</button>
  <button class="filter-btn" data-f="shortlisted" onclick="setFilter('shortlisted',this)">⭐ Shortlisted</button>
</div>

<div class="stats">
  <div class="stat"><div class="num" id="totalCount">0</div><div class="label">Venues Found</div></div>
  <div class="stat"><div class="num" id="lowerCount">0</div><div class="label">Lower Manhattan</div></div>
  <div class="stat"><div class="num" id="byoCount">0</div><div class="label">BYO Alcohol ✓</div></div>
  <div class="stat"><div class="num" id="shortCount">0</div><div class="label">Shortlisted</div></div>
</div>

<div class="venue-grid" id="venueGrid"></div>

<div class="tracker-section">
  <h2>⭐ Shortlisted Venues</h2>
  <p id="noShortlist">Click the ⭐ on any venue card to add it to your shortlist.</p>
  <table class="tracker-table" id="shortlistTable" style="display:none;">
    <thead><tr><th>Venue</th><th>Neighborhood</th><th>Capacity</th><th>Price</th><th>Distance</th><th>Link</th><th></th></tr></thead>
    <tbody id="shortlistBody"></tbody>
  </table>
</div>

<div class="footer">
  🌳 Treehouse Venue Finder / Data sourced from TagVenue, Peerspace, Splacer, EventUp / Last updated: March 3, 2026
</div>

<script>
var venues = [
  // LOWER MANHATTAN / DOWNTOWN
  // WEST VILLAGE & IMMEDIATE NEIGHBORS (0-0.5 mi)
  { name: "Cooper Classics Collection", neighborhood: "West Village", type: "gallery", capacity: 150, capacitySit: 150, price: "From $15,000/session", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/68619/cooper-classics-collection/main-gallery", source: "TagVenue", features: ["BYO alcohol","Play your own music","Gallery","Private space"], desc: "West Village gallery. Premium price point but stunning visual identity. 150 cap.", match: 75, lower: true, emoji: "🖼️", dist: 0.0 },
  { name: "DRAIS SUPPER CLUB", neighborhood: "West Village", type: "bar", capacity: 500, capacitySit: 172, price: "From $1,000 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/103709/drais-supper-club/main-floor", source: "TagVenue", features: ["Private space","Restaurant","Dance Floor"], desc: "West Village supper club. Main floor 500 standing, lounge 250 standing. High energy nightlife venue.", match: 90, lower: true, emoji: "🍾", dist: 0.1 },
  { name: "Ideal Glass Studios", neighborhood: "Greenwich Village", type: "event", capacity: 150, capacitySit: 150, price: "From $500/hr", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/51449/ideal-glass-studios/mansion", source: "TagVenue", features: ["Private space","Event Venue"], desc: "Greenwich Village mansion event venue. 150 cap. Elegant, unique character.", match: 85, lower: true, emoji: "🏛️", dist: 0.2 },
  { name: "Josie Woods Pub", neighborhood: "Greenwich Village", type: "bar", capacity: 160, capacitySit: 100, price: "From $8,890/session", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/38849/josie-woods-pub/entire-venue", source: "TagVenue", features: ["Whole venue","Pub"], desc: "Greenwich Village pub, full buyout. 160 standing. Classic Village vibes.", match: 78, lower: true, emoji: "🍺", dist: 0.2 },
  { name: "Folly NYC", neighborhood: "South Village", type: "bar", capacity: 175, capacitySit: 80, price: "From $6,000 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/38248/folly-nyc/entire-space-buyout", source: "TagVenue", features: ["BYO alcohol","Play your own music","Whole venue","Bar"], desc: "South Village pub, full buyout. 175 standing. Steps from West Village.", match: 78, lower: true, emoji: "🍻", dist: 0.3 },
  { name: "Houston Hall", neighborhood: "South Village", type: "bar", capacity: 400, capacitySit: 220, price: "From $12,000 min spend", priceNote: "per day", url: "https://www.tagvenue.com/us/rooms/new-york/98129/houston-hall/entire-hall", source: "TagVenue", features: ["Whole venue","Bar"], desc: "Massive beer hall in South Village. 400 standing. Perfect for high-energy events.", match: 88, lower: true, emoji: "🍺", dist: 0.3 },
  { name: "Pera SoHo", neighborhood: "South Village", type: "restaurant", capacity: 250, capacitySit: 220, price: "From $10,890 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/32601/pera-soho/entire-restaurant", source: "TagVenue", features: ["Whole venue","Restaurant"], desc: "Full restaurant buyout in South Village. 250 standing. Upscale Mediterranean.", match: 75, lower: true, emoji: "🍽️", dist: 0.3 },
  { name: "Triangle Loft (Connect-South)", neighborhood: "Meatpacking District", type: "loft", capacity: 225, capacitySit: 225, price: "From $3,000/hr", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/38458/triangle-loft/triangle-loft-connect-south", source: "TagVenue", features: ["Private space","Loft"], desc: "Meatpacking loft. 225 cap. Multiple configurations available (Create, 4S, Full Floor). Premium.", match: 92, lower: true, emoji: "🔺", dist: 0.3 },
