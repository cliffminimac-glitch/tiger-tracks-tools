  { name: "W Broadway ART X POPUP", neighborhood: "SoHo", type: "warehouse", capacity: 300, capacitySit: 185, price: "From $9,000/day", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/95679/w-broadway-art-x-popup-space/entire-venue", source: "TagVenue", features: ["BYO alcohol","Play your own music","Whole venue"], desc: "SoHo warehouse/popup space. 300 standing. Raw creative canvas, perfect for themed production.", match: 96, lower: true, emoji: "🏗️", dist: 0.5 },
