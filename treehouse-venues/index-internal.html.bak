];

var currentFilter = 'all';
var shortlist = JSON.parse(localStorage.getItem('th_shortlist') || '[]');

function renderVenues() {
  var q = document.getElementById('venueSearch').value.toLowerCase();
  var grid = document.getElementById('venueGrid');
  var html = '';
  var shown = 0;
  var lowerCount = 0;

  venues.sort(function(a,b) { return a.dist - b.dist; });

  venues.forEach(function(v, i) {
    if (v.lower) lowerCount++;

    // Filter
    if (currentFilter === 'shortlisted' && shortlist.indexOf(v.name) === -1) return;
    if (currentFilter === 'lower' && !v.lower) return;
    if (currentFilter === 'byo' && v.features.indexOf('BYO alcohol') === -1) return;
    if (currentFilter === 'music' && v.features.indexOf('Play your own music') === -1) return;
    if (currentFilter === 'ready' && (v.features.indexOf('BYO alcohol') === -1 || v.features.indexOf('Play your own music') === -1)) return;
    if (currentFilter === 'cap250' && v.capacity < 250) return;
    if (['all','shortlisted','lower','byo','music','ready','cap250'].indexOf(currentFilter) === -1 && v.type !== currentFilter) return;
    if (q && v.name.toLowerCase().indexOf(q) === -1 && v.neighborhood.toLowerCase().indexOf(q) === -1 && v.desc.toLowerCase().indexOf(q) === -1) return;

    var starred = shortlist.indexOf(v.name) !== -1;
    var hasBYO = v.features.indexOf('BYO alcohol') !== -1;
    var hasMusic = v.features.indexOf('Play your own music') !== -1;
    var dimClass = (!hasBYO && !hasMusic) ? ' no-byo' : (!hasBYO || !hasMusic) ? '' : '';
    shown++;

    html += '<div class="venue-card' + dimClass + '" id="vc_' + i + '">';
    html += '<div class="venue-img">' + v.emoji;
    html += '<span class="source-tag">' + v.source + '</span>';
    html += '<span class="match-score">📍 ' + v.dist + ' mi</span>';
    html += '<span class="music-badge ' + (hasMusic ? 'yes' : 'no') + '">' + (hasMusic ? '🎵 Loud Music ✓' : '🔇 Music Not Confirmed') + '</span>';
    html += '<span class="byo-badge ' + (hasBYO ? 'yes' : 'no') + '">' + (hasBYO ? '🍾 BYO Alcohol ✓' : '⚠️ BYO Not Confirmed') + '</span>';
    if (v.capacity >= 250) html += '<span class="cap-badge">🔥 250+ Capacity</span>';
    html += '</div>';
    html += '<div class="venue-body">';
    html += '<div style="display:flex;justify-content:space-between;align-items:start;">';
    html += '<div><h3>' + v.name + '</h3>';
    html += '<div class="neighborhood">' + v.neighborhood + ' - ' + v.dist + ' mi from West Village</div></div>';
    html += '<span style="cursor:pointer;font-size:1.25rem;" onclick="toggleShortlist(\'' + v.name.replace(/'/g,"\\'") + '\')">' + (starred ? '⭐' : '☆') + '</span>';
    html += '</div>';
    html += '<p style="font-size:.8rem;color:var(--text-dim);margin:.5rem 0;">' + v.desc + '</p>';
    html += '<div class="venue-meta">';
    v.features.forEach(function(f) {
      var cls = (f === 'BYO alcohol' || f === 'Play your own music') ? 'green' : '';
      html += '<span class="tag ' + cls + '">' + f + '</span>';
    });
    html += '</div>';
    var pct = Math.min(100, Math.round((v.capacity / 500) * 100));
    html += '<div class="venue-capacity-bar">';
    html += '<div><div class="cap-num">' + v.capacity + '</div><div class="cap-label">standing</div></div>';
    if (v.capacitySit) {
      html += '<div class="cap-divider"></div>';
      html += '<div><div class="cap-num">' + v.capacitySit + '</div><div class="cap-label">seated</div></div>';
    }
    html += '<div class="cap-divider"></div>';
    html += '<div class="cap-meter"><div class="cap-meter-fill" style="width:' + pct + '%"></div></div>';
    html += '</div>';
    html += '<div class="venue-details">';
    html += '<div class="venue-price">' + v.price + '</div>';
    html += '<a href="' + v.url + '" target="_blank" class="venue-link">View on ' + v.source + ' →</a>';
    html += '</div></div></div>';
  });

  grid.innerHTML = html || '<p style="text-align:center;color:var(--text-dim);padding:2rem;">No venues match your filters.</p>';
  var byoCount = venues.filter(function(v) { return v.features.indexOf('BYO alcohol') !== -1; }).length;
  document.getElementById('totalCount').textContent = venues.length;
  document.getElementById('lowerCount').textContent = lowerCount;
  document.getElementById('byoCount').textContent = byoCount;
  document.getElementById('shortCount').textContent = shortlist.length;
  renderShortlist();
}

function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  renderVenues();
}

function filterVenues() { renderVenues(); }

function toggleShortlist(name) {
  var idx = shortlist.indexOf(name);
  if (idx === -1) shortlist.push(name);
  else shortlist.splice(idx, 1);
  localStorage.setItem('th_shortlist', JSON.stringify(shortlist));
  renderVenues();
}

function renderShortlist() {
  var table = document.getElementById('shortlistTable');
  var body = document.getElementById('shortlistBody');
  var msg = document.getElementById('noShortlist');
  if (!shortlist.length) { table.style.display = 'none'; msg.style.display = ''; return; }
  table.style.display = ''; msg.style.display = 'none';
  var html = '';
  shortlist.forEach(function(name) {
    var v = venues.find(function(x) { return x.name === name; });
    if (!v) return;
    html += '<tr>';
    html += '<td style="font-weight:600;">' + v.emoji + ' ' + v.name + '</td>';
    html += '<td>' + v.neighborhood + '</td>';
    html += '<td>👥 ' + v.capacity + '</td>';
    html += '<td style="color:var(--gold);">' + v.price + '</td>';
    html += '<td><span style="color:var(--accent);font-weight:700;">📍 ' + v.dist + ' mi</span></td>';
    html += '<td><a href="' + v.url + '" target="_blank" class="venue-link" style="font-size:.7rem;">View →</a></td>';
    html += '<td><span style="cursor:pointer;" onclick="toggleShortlist(\'' + name.replace(/'/g,"\\'") + '\')">🗑</span></td>';
    html += '</tr>';
  });
  body.innerHTML = html;
}

renderVenues();
</script>
</body>
</html>
