  { name: "Common Ground Bar", neighborhood: "Meatpacking District", type: "bar", capacity: 160, capacitySit: 100, price: "From $5,000 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/104430/common-ground-bar/full-venue-buyout", source: "TagVenue", features: ["Whole venue","Bar"], desc: "Meatpacking bar, full buyout. 160 standing. Trendy neighborhood.", match: 82, lower: true, emoji: "🍸", dist: 0.4 },
  { name: "La Victoria", neighborhood: "Chelsea", type: "bar", capacity: 150, capacitySit: 142, price: "From $5,000 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/51211/la-victoria/full-venue", source: "TagVenue", features: ["Whole venue","Nightclub"], desc: "Chelsea nightclub. 150 cap. Full venue buyout. Party-ready.", match: 85, lower: false, emoji: "🎵", dist: 0.5 },
  { name: "Rumi Event Space", neighborhood: "Chelsea", type: "event", capacity: 650, capacitySit: 250, price: "From $15,000 min spend", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/47278/rumi-event-space/entire-venue", source: "TagVenue", features: ["Whole venue","Event Venue"], desc: "Massive Chelsea event space. 650 standing. For when Treehouse goes HUGE.", match: 78, lower: false, emoji: "🏛️", dist: 0.6 },

