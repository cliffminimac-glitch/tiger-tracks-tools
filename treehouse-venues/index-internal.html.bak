  { name: "Shapira's Cozy Lounge", neighborhood: "Little Italy", type: "bar", capacity: 248, capacitySit: 40, price: "From $650/hr", priceNote: "hire fee", url: "https://www.tagvenue.com/us/rooms/new-york/87785/shapiras-cozy-lounge/entire-venue", source: "TagVenue", features: ["BYO alcohol","Play your own music","Whole venue"], desc: "Little Italy lounge. 248 standing. Surprisingly big for 'cozy'. BYO confirmed.", match: 86, lower: true, emoji: "🛋️", dist: 0.8 },
