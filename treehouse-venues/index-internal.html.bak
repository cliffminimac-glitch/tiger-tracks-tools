  { name: "Gran Morsi (Private Space)", neighborhood: "TriBeCa", type: "restaurant", capacity: 175, capacitySit: 125, price: "From $90/person", priceNote: "per session", url: "https://www.tagvenue.com/us/rooms/new-york/28237/gran-morsi/private-event-space", source: "TagVenue", features: ["BYO alcohol","Play your own music","Private space"], desc: "TriBeCa private event space inside a restaurant. 175 standing.", match: 80, lower: true, emoji: "🍽️", dist: 0.8 },
